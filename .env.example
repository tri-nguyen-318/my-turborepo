# Copy this file to .env and fill in the values before running docker compose.
# cp .env.example .env

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5434/mydatabase?schema=public
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-please

# ── Google OAuth (console.cloud.google.com) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── S3 / Storage ──────────────────────────────────────────────────────────────
# Docker: points to the minio container
# Production (Cloudflare R2, AWS S3, etc.): set to your provider endpoint
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpassword
# Public bucket: avatars, CVs — set Access Policy to "Public" in MinIO console
S3_PUBLIC_BUCKET=public-uploads
# Private bucket: user-uploaded files — private, accessed via presigned URLs
S3_PRIVATE_BUCKET=private-uploads
# Public-facing URL for the public bucket (R2: https://pub-<id>.r2.dev, MinIO: leave empty)
S3_PUBLIC_URL=

# ── Groq AI (free at console.groq.com) ───────────────────────────────────────
GROQ_API_KEY=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend reachable from the user's browser.
# Change this if deploying to a remote server (e.g. https://api.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:3001
