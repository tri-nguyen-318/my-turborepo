datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                 Int            @id @default(autoincrement())
  email              String         @unique
  password           String?
  name               String?
  googleId           String?
  avatarUrl          String?
  hashedRefreshToken String?
  role               UserRole       @default(USER)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  personalInfo       PersonalInfo?
  uploadedFiles      UploadedFile[]
  imagePosts         ImagePost[]
  imagePostLikes     ImagePostLike[]
  imagePostComments  ImagePostComment[]
}

model UploadedFile {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  location    String
  filename    String
  contentType String?
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model PersonalInfo {
  id       Int     @id @default(autoincrement())
  userId   Int     @unique
  user     User    @relation(fields: [userId], references: [id])
  name     String?
  role     String?
  bio      String?
  phone    String?
  location String?
  email    String?
  github   String?
  linkedin String?
  website  String?
  cvUrl    String?
  career   Json?
  skills   String[]
}

model ImagePost {
  id           Int                @id @default(autoincrement())
  userName     String
  userId       Int?
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  caption      String
  url          String
  likes        Int                @default(0)
  comments     Int                @default(0)
  blurDataUrl  String?
  createdAt    DateTime           @default(now())
  commentsList ImagePostComment[] @relation("commentsList")
  likesList    ImagePostLike[]    @relation("likesList")
}

model ImagePostLike {
  id          Int       @id @default(autoincrement())
  imagePost   ImagePost @relation("likesList", fields: [imagePostId], references: [id], onDelete: Cascade)
  imagePostId Int
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([imagePostId, userId])
}

model ImagePostComment {
  id          Int       @id @default(autoincrement())
  imagePost   ImagePost @relation("commentsList", fields: [imagePostId], references: [id], onDelete: Cascade)
  imagePostId Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  userName    String
  body        String
  createdAt   DateTime  @default(now())
}

enum InvoiceStatus {
  UNPAID
  PAID
}

model Invoice {
  id              Int           @id @default(autoincrement())
  customer        String
  customerEmail   String
  amount          Float
  date            DateTime
  status          InvoiceStatus @default(UNPAID)
  notes           String?
  paymentToken    String?
  paymentTokenExp DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
