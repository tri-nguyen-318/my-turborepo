datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int            @id @default(autoincrement())
  email              String         @unique
  password           String?
  name               String?
  googleId           String?
  avatarUrl          String?
  hashedRefreshToken String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  personalInfo       PersonalInfo?
  uploadedFiles      UploadedFile[]
}

model UploadedFile {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  location    String
  filename    String
  contentType String?
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model PersonalInfo {
  id       Int     @id @default(autoincrement())
  userId   Int     @unique
  user     User    @relation(fields: [userId], references: [id])
  name     String?
  role     String?
  bio      String?
  phone    String?
  location String?
  email    String?
  github   String?
  linkedin String?
  website  String?
  cvUrl    String?
  career   Json?
  skills   String[]
}

enum InvoiceStatus {
  UNPAID
  PAID
}

model Invoice {
  id              Int           @id @default(autoincrement())
  customer        String
  customerEmail   String
  amount          Float
  date            DateTime
  status          InvoiceStatus @default(UNPAID)
  notes           String?
  paymentToken    String?
  paymentTokenExp DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
