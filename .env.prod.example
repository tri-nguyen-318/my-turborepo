# === App ===
NODE_ENV=production
PORT=3003
FRONTEND_URL=https://access.pavietnam.vn

# === PostgreSQL (Supabase) ===
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# === MongoDB (Atlas) ===
MONGO_URI=mongodb+srv://[user]:[password]@cluster0.[id].mongodb.net/mydb?appName=Cluster0

# === Auth ===
JWT_SECRET=generate-with-openssl-rand-hex-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://[your-render-service].onrender.com/auth/google/callback

# === File Storage (S3-compatible) — optional for demo ===
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=uploads
